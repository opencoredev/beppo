---
import Layout from "../layouts/Layout.astro";
import {
  DISCORD_URL,
  RELEASES_URL,
  REPO_URL,
} from "../lib/releases";

const features = [
  {
    title: "Resilient session handling",
    body: "Reconnects, provider hiccups, and long-running turns are treated like product constraints, not edge cases.",
  },
  {
    title: "Desktop-first without clutter",
    body: "Beppo is built for focused local work, not for turning your agent into a maze of side-panels and browser chrome.",
  },
  {
    title: "Electrobun all the way down",
    body: "One fast desktop shell, one shared UI, and a tighter path between session orchestration and what you see on screen.",
  },
];

const pillars = [
  "Predictable under load",
  "Open source and inspectable",
  "Designed for long-running coding sessions",
  "Built for Codex-first workflows today",
];
---

<Layout
  title="Beppo - Calm control for coding agents"
  description="Beppo is a desktop-first workspace for long-running coding agents, with resilient sessions, cleaner branching, and a calmer UI."
>
  <section class="hero">
    <div class="hero-copy">
      <span class="eyebrow">Electrobun desktop workspace</span>
      <h1>Calm control for coding agents.</h1>
      <p class="lede">
        Beppo gives long-running agent sessions a steadier home: cleaner branching, clearer state,
        and less interface noise when the work gets messy.
      </p>

      <div class="hero-actions">
        <a id="download-btn" href={RELEASES_URL} class="primary-button" target="_blank" rel="noopener noreferrer">
