---
const githubUrl = "https://github.com/opencoredev/beppo";
const releaseUrl = "https://github.com/opencoredev/beppo/releases";
const discordUrl = "https://discord.gg/jn4EGJjrvv";

const notes = [
  "Desktop-first workflow",
  "Codex-first sessions",
  "Forked and rebranded as Beppo",
];

const details = [
  {
    title: "Cleaner sessions",
    body: "Keep agent work readable while turns stream, reconnect, and recover.",
  },
  {
    title: "One focused surface",
    body: "Desktop depth with web visibility, without making the product feel busy.",
  },
  {
    title: "Built to evolve",
    body: "A strong fork with room for its own product voice, visuals, and workflow ideas.",
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Beppo is a desktop-first AI coding workspace with calmer sessions, cleaner branching, and a sharper interface for serious agent work."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon-16x16.png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>Beppo</title>
  </head>
  <body>
    <div class="page">
      <nav class="nav">
        <a href="/" class="nav-brand" aria-label="Beppo home">
          <img src="/icon.jpg" alt="Beppo" class="nav-icon" />
          <span class="nav-wordmark">Beppo</span>
        </a>
        <div class="nav-links">
          <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="nav-link">GitHub</a>
          <a href={releaseUrl} target="_blank" rel="noopener noreferrer" class="nav-link nav-link-cta">
            Download
            <span class="nav-github-arrow" aria-hidden="true">&#8599;</span>
          </a>
        </div>
      </nav>

      <main class="main">
        <div class="hero-intro">
          <div class="hero-pill">Rebranded from a fork into Beppo</div>
          <h1 class="tagline">Beppo is a calmer way to code with AI.</h1>
          <p class="subtagline">
            A desktop-first workspace for running code agents with clearer sessions, cleaner
            branching, and a UI that feels focused instead of loud.
          </p>
        </div>

        <div class="note-row" aria-label="Beppo highlights">
          {notes.map((note) => <span class="note-chip">{note}</span>)}
        </div>

        <div class="hero-actions">
          <a href={releaseUrl} target="_blank" rel="noopener noreferrer" class="hero-button">
            Download now
          </a>
          <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="hero-secondary">
            View source
          </a>
        </div>

        <div class="screenshot-wrap">
          <div class="screenshot-shell">
            <div class="screenshot-bar">
              <span></span>
              <span></span>
              <span></span>
            </div>
            <img src="/screenshot.jpeg" alt="Beppo" class="screenshot" />
          </div>
        </div>

        <section class="details" aria-label="What Beppo is for">
          {details.map((detail) => (
            <article class="detail-card">
              <h2>{detail.title}</h2>
              <p>{detail.body}</p>
            </article>
          ))}
        </section>
      </main>

      <footer class="footer">
        <div class="footer-brand">
          <img src="/full-logo.png" alt="Beppo" class="footer-logo" />
          <span class="footer-copy">&copy; {new Date().getFullYear()} T3 Tools Inc</span>
        </div>
        <div class="footer-links">
          <a href={githubUrl} target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href={releaseUrl} target="_blank" rel="noopener noreferrer">Releases</a>
          <a href={discordUrl} target="_blank" rel="noopener noreferrer">Discord</a>
        </div>
      </footer>
    </div>
  </body>
</html>

<style>
  :root {
    --background: color-mix(in srgb, var(--color-neutral-950, #0a0a0a) 95%, white);
    --foreground: #f5f7fb;
    --card: rgba(255, 255, 255, 0.04);
    --card-foreground: #f5f7fb;
    --primary: oklch(0.588 0.217 264);
    --primary-foreground: #ffffff;
    --secondary: rgba(255, 255, 255, 0.05);
    --muted: rgba(255, 255, 255, 0.04);
    --muted-foreground: rgba(229, 236, 246, 0.68);
    --accent: rgba(255, 255, 255, 0.04);
    --border: rgba(255, 255, 255, 0.08);
    --ring: oklch(0.588 0.217 264);
    --shadow-soft: 0 26px 90px color-mix(in srgb, var(--primary) 18%, transparent);
    --shadow-card: 0 18px 42px rgba(0, 0, 0, 0.34);
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    color-scheme: dark;
    scroll-behavior: smooth;
  }

  body {
    background:
      radial-gradient(circle at top center, color-mix(in srgb, var(--primary) 18%, transparent) 0%, transparent 34%),
      radial-gradient(circle at top right, rgba(56, 189, 248, 0.12) 0%, transparent 26%),
      linear-gradient(180deg, #090b11 0%, #0d1119 48%, #090c12 100%);
    color: var(--foreground);
    font-family: "Geist", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    min-height: 100vh;
    overflow-x: hidden;
  }

  body::after {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 256px 256px;
    z-index: 9999;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  .page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 2.5rem;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .nav-icon {
    width: 34px;
    height: 34px;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 12px 28px color-mix(in srgb, var(--primary) 26%, transparent);
  }

  .nav-wordmark {
    font-size: 0.98rem;
    font-weight: 600;
    letter-spacing: -0.03em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .nav-link {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0 0.95rem;
    border: 1px solid transparent;
    border-radius: 999px;
    color: var(--muted-foreground);
    font-size: 0.9rem;
    transition:
      color 0.2s ease,
      background-color 0.2s ease,
      border-color 0.2s ease,
      transform 0.2s ease;
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--foreground);
    background: color-mix(in srgb, var(--primary) 12%, transparent);
    border-color: color-mix(in srgb, var(--primary) 24%, transparent);
    outline: none;
  }

  .nav-link-cta {
    color: var(--primary);
    border-color: color-mix(in srgb, var(--primary) 24%, transparent);
    background: color-mix(in srgb, var(--primary) 12%, transparent);
  }

  .nav-github-arrow {
    display: inline-block;
    transition: transform 0.2s ease;
  }

  .nav-link-cta:hover .nav-github-arrow,
  .nav-link-cta:focus-visible .nav-github-arrow {
    transform: translateX(2px) translateY(-1px);
  }

  .main {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 3vh 1.5rem 0;
  }

  .hero-intro {
    max-width: 56rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero-pill {
    min-height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 0.9rem;
    border: 1px solid color-mix(in srgb, var(--primary) 22%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--primary) 11%, transparent);
    color: var(--primary);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    margin-bottom: 0.9rem;
  }

  .tagline {
    font-weight: 600;
    font-size: clamp(2.5rem, 5.3vw, 4rem);
    letter-spacing: -0.055em;
    line-height: 1.02;
    margin: 0 0 0.85rem;
    opacity: 0;
    animation: fade-in 0.9s ease-out forwards;
  }

  .subtagline {
    max-width: 38rem;
    color: var(--muted-foreground);
    font-size: clamp(1rem, 2vw, 1.125rem);
    line-height: 1.65;
    opacity: 0;
    animation: fade-in 0.9s ease-out 0.08s forwards;
  }

  .note-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin: 1.25rem 0 0;
    opacity: 0;
    animation: fade-in 0.9s ease-out 0.14s forwards;
  }

  .note-chip {
    min-height: 38px;
    display: inline-flex;
    align-items: center;
    padding: 0 0.95rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.04);
    color: var(--foreground);
    font-size: 0.875rem;
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.16);
  }

  .hero-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.85rem;
    flex-wrap: wrap;
    margin: 1rem 0 1.1rem;
    opacity: 0;
    animation: fade-in 0.9s ease-out 0.2s forwards;
  }

  .hero-button,
  .hero-secondary {
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 1.25rem;
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 600;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease;
  }

  .hero-button {
    background: var(--primary);
    color: var(--primary-foreground);
    box-shadow: 0 18px 36px color-mix(in srgb, var(--primary) 28%, transparent);
  }

  .hero-button:hover,
  .hero-button:focus-visible,
  .hero-secondary:hover,
  .hero-secondary:focus-visible {
    transform: translateY(-1px);
    outline: none;
  }

  .hero-secondary {
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.04);
    color: var(--foreground);
  }

  .hero-secondary:hover,
  .hero-secondary:focus-visible {
    border-color: color-mix(in srgb, var(--primary) 26%, transparent);
    background: color-mix(in srgb, var(--primary) 10%, transparent);
  }

  .screenshot-wrap {
    margin: 0 auto;
    width: min(95vw, 1320px);
    opacity: 0;
    transform: scale(0.985);
    animation: screenshot-in 1s ease-out 0.24s forwards;
  }

  .screenshot-shell {
    padding: 0.9rem 0.9rem 0;
    border-radius: 24px;
    border: 1px solid color-mix(in srgb, var(--primary) 16%, var(--border));
    background:
      linear-gradient(180deg, rgba(21, 27, 38, 0.96), rgba(12, 17, 26, 0.96));
    box-shadow: var(--shadow-soft);
  }

  .screenshot-bar {
    display: flex;
    gap: 0.45rem;
    padding: 0 0.15rem 0.8rem;
  }

  .screenshot-bar span {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--primary) 30%, transparent);
  }

  .screenshot-bar span:first-child {
    background: #ffb4a2;
  }

  .screenshot-bar span:nth-child(2) {
    background: #89cff0;
  }

  .screenshot {
    width: 100%;
    display: block;
    border-radius: 16px;
    border: 1px solid color-mix(in srgb, var(--primary) 12%, var(--border));
    mask-image: linear-gradient(to bottom, black 86%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 86%, transparent 100%);
  }

  .screenshot-wrap::after {
    content: "";
    display: block;
    width: 100%;
    height: 120px;
    margin-top: -1px;
    opacity: 0.08;
    transform: scaleY(-1);
    background: linear-gradient(180deg, rgba(88, 140, 255, 0.18), transparent);
    mask-image: linear-gradient(to bottom, black 0%, transparent 60%);
    -webkit-mask-image: linear-gradient(to bottom, black 0%, transparent 60%);
    pointer-events: none;
  }

  .details {
    width: min(1040px, 100%);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin: 1.75rem auto 0;
    padding: 0 0 2rem;
  }

  .detail-card {
    padding: 1.25rem;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: var(--card);
    color: var(--card-foreground);
    box-shadow: var(--shadow-card);
    backdrop-filter: blur(10px);
  }

  .detail-card h2 {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }

  .detail-card p {
    color: var(--muted-foreground);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.5rem 2.5rem;
    font-size: 0.84rem;
    color: var(--muted-foreground);
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }

  .footer-logo {
    width: 82px;
    height: auto;
    opacity: 0.9;
  }

  .footer-links {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .footer-links a {
    color: var(--muted-foreground);
    transition: color 0.2s ease;
  }

  .footer-links a:hover,
  .footer-links a:focus-visible {
    color: var(--foreground);
    outline: none;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes screenshot-in {
    from {
      opacity: 0;
      transform: scale(0.985);
    }

    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @media (max-width: 900px) {
    .details {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .nav {
      padding: 1.25rem 1.25rem 0.75rem;
      flex-direction: column;
      align-items: flex-start;
    }

    .nav-links {
      width: 100%;
      flex-wrap: wrap;
    }

    .main {
      padding-top: 5vh;
    }

    .tagline {
      margin-bottom: 0.9rem;
    }

    .note-row {
      gap: 0.6rem;
    }

    .screenshot-wrap {
      width: 95vw;
    }

    .screenshot-shell {
      border-radius: 20px;
      padding: 0.75rem 0.75rem 0;
    }

    .footer {
      padding: 1.25rem;
      flex-direction: column;
      align-items: flex-start;
    }

    .footer-brand {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.45rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }

    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
  }
</style>
