.275 4.684 2.939 5.143 7.255"/></g></svg>
          <span id="download-label">Download desktop</span>
        </a>
        <a href="/download" class="secondary-link">See all downloads</a>
        <a href={REPO_URL} class="secondary-link" target="_blank" rel="noopener noreferrer">Browse source</a>
      </div>

      <div class="pillars" aria-label="Beppo qualities">
        {pillars.map((pillar) => (
          <span class="pillar">{pillar}</span>
        ))}
      </div>
    </div>

    <div class="hero-panel">
      <div class="hero-panel-top">
        <span class="panel-kicker">What Beppo optimizes for</span>
        <p>
          Long-running coding work should feel steady. Beppo keeps the agent surface readable,
          lets the desktop shell stay fast, and avoids turning the product into a novelty browser.
        </p>
      </div>

      <div class="proof-grid">
        <article class="proof-card">
          <span class="proof-label">Desktop-first</span>
          <strong>Shared web UI with a focused Electrobun shell.</strong>
        </article>
        <article class="proof-card">
          <span class="proof-label">Open by design</span>
          <strong>GitHub releases, inspectable code, and visible product direction.</strong>
        </article>
        <article class="proof-card">
          <span class="proof-label">Brand with intent</span>
          <strong>Beppo keeps its own voice while learning from great open tools.</strong>
        </article>
      </div>
    </div>
  </section>

  <section class="showcase">
    <div class="showcase-header">
      <span class="section-tag">Real interface</span>
      <h2>Built for actual sessions, not just launch-day screenshots.</h2>
      <p>
        The homepage keeps the product front and center: a real Beppo capture, a clearer story,
        and language that matches the app we are actually building.
      </p>
    </div>

    <div class="shot-frame">
      <div class="shot-bar">
        <span></span>
        <span></span>
        <span></span>
      </div>
      <img
        src="/screenshot.jpeg"
        alt="Beppo interface showing an agent-driven coding session"
        width="2764"
        height="1712"
        class="shot-image"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </section>

  <section class="feature-block">
    <div class="feature-intro">
      <span class="section-tag">Why it feels different</span>
      <h2>Beppo is tuned for steadier agent work.</h2>
      <p>
        It takes cues from the best ideas in the space while staying grounded in Beppo&rsquo;s own
        priorities: reliability, performance, and interface restraint.
      </p>
    </div>

    <div class="feature-grid">
      {features.map((feature) => (
        <article class="feature-card">
          <h3>{feature.title}</h3>
          <p>{feature.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="inspiration">
    <div>
      <span class="section-tag">Inspired, not copied</span>
      <h2>Good open tools raise the bar for everyone.</h2>
    </div>
    <p>
      Beppo openly credits reference projects like
      <a href="https://github.com/Emanuele-web04/dpcode" target="_blank" rel="noopener noreferrer"> DP Code</a>
      for product-quality ambition and
      <a href="https://github.com/steipete/codexbar" target="_blank" rel="noopener noreferrer"> CodexBar</a>
      for provider-limit clarity. The goal is not to transplant someone else&rsquo;s product, but to
      build a sharper Beppo from those lessons.
    </p>
  </section>

  <section class="final-cta">
    <div>
      <span class="section-tag">Start here</span>
      <h2>Download Beppo, inspect the repo, and follow the project in public.</h2>
    </div>

    <div class="cta-actions">
      <a href={RELEASES_URL} class="primary-button" target="_blank" rel="noopener noreferrer">
        Latest release
      </a>
      <a href={DISCORD_URL} class="secondary-link" target="_blank" rel="noopener noreferrer">
        Join Discord
      </a>
    </div>
  </section>
</Layout>

<script>
  import { fetchLatestRelease, RELEASES_URL, type ReleaseAsset } from "../lib/releases";

  type Platform = { os: "mac" | "win" | "linux"; label: string; arch?: string };

  function detectPlatform(): Platform | null {
    const ua = navigator.userAgent;
    if (/Win/i.test(ua)) return { os: "win", label: "Download for Windows" };
    if (/Mac/i.test(ua)) {
      return { os: "mac", label: "Download for macOS", arch: "arm64" };
    }
    if (/Linux/i.test(ua)) return { os: "linux", label: "Download for Linux" };
    return null;
  }

  function pickAsset(assets: ReleaseAsset[], platform: Platform): string | null {
    if (platform.os === "win") {
      return assets.find((asset) => asset.name.endsWith("-x64.exe"))?.browser_download_url ?? null;
    }
    if (platform.os === "mac") {
      const preferred = assets.find((asset) => asset.name.endsWith(`-${platform.arch}.dmg`));
      const fallback = assets.find((asset) => asset.name.endsWith(".dmg"));
      return (preferred ?? fallback)?.browser_download_url ?? null;
    }
    return assets.find((asset) => asset.name.endsWith(".AppImage"))?.browser_download_url ?? null;
  }

  async function init() {
    const button = document.getElementById("download-btn") as HTMLAnchorElement | null;
    const label = document.getElementById("download-label");
    if (!button || !label) return;

    const platform = detectPlatform();
    if (!platform) return;

    document.documentElement.dataset.platform = platform.os;
    label.textContent = platform.label;

    try {
      const release = await fetchLatestRelease();
      const url = pickAsset(release.assets ?? [], platform);
      if (!url) return;

      button.href = url;
      button.removeAttribute("target");
      button.removeAttribute("rel");
    } catch {
      button.href = RELEASES_URL;
    }
  }

  init();
</script>

<style>
  .hero,
  .showcase,
  .feature-block,
  .inspiration,
  .final-cta {
    animation: rise-in 0.6s ease forwards;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
    gap: 1.5rem;
    align-items: stretch;
    padding-top: 1.25rem;
  }

  .hero-copy,
  .hero-panel,
  .showcase,
  .feature-block,
  .inspiration,
  .final-cta {
    border: 1px solid var(--line);
    background: linear-gradient(180deg, rgba(11, 18, 28, 0.9), rgba(8, 13, 21, 0.82));
    box-shadow: var(--shadow);
  }

  .hero-copy,
  .hero-panel {
    border-radius: var(--radius-xl);
    padding: clamp(1.6rem, 3vw, 2.35rem);
  }

  .eyebrow,
  .section-tag,
  .panel-kicker,
  .proof-label {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--accent);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero h1,
  .showcase h2,
  .feature-intro h2,
  .inspiration h2,
  .final-cta h2 {
    font-family: var(--font-brand);
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 0.96;
  }

  .hero h1 {
    max-width: 11ch;
    margin-top: 0.9rem;
    font-size: clamp(3.5rem, 9vw, 6.8rem);
  }

  .lede {
    max-width: 42rem;
    margin-top: 1.25rem;
    color: var(--fg-soft);
    font-size: clamp(1.02rem, 2vw, 1.18rem);
    line-height: 1.8;
  }

  .hero-actions,
  .cta-actions {
    margin-top: 1.7rem;
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .primary-button,
  .secondary-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
    min-height: 3rem;
    border-radius: 999px;
    padding: 0.8rem 1.2rem;
    transition: transform 0.16s ease, border-color 0.16s ease, color 0.16s ease, background 0.16s ease;
  }

  .primary-button {
    color: #071019;
    background: linear-gradient(135deg, #d8f3ff, #ffcf98);
    font-weight: 700;
    box-shadow: 0 12px 26px rgba(0, 0, 0, 0.18);
  }

  .primary-button:hover,
  .secondary-link:hover {
    transform: translateY(-1px);
  }

  .secondary-link {
    border: 1px solid var(--line);
    color: var(--fg-soft);
    background: rgba(255, 255, 255, 0.02);
  }

  .secondary-link:hover {
    border-color: var(--line-strong);
    color: var(--fg);
    background: rgba(255, 255, 255, 0.045);
  }

  .download-icon {
    display: none;
    width: 1em;
    height: 1em;
    flex-shrink: 0;
  }

  :global([data-platform="mac"]) .download-icon--apple,
  :global([data-platform="win"]) .download-icon--windows,
  :global([data-platform="linux"]) .download-icon--linux {
    display: block;
  }

  .pillars {
    margin-top: 1.7rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .pillar {
    padding: 0.55rem 0.85rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--fg-soft);
    font-size: 0.9rem;
  }

  .hero-panel {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.2rem;
  }

  .hero-panel-top p {
    margin-top: 0.8rem;
    color: var(--fg-soft);
    line-height: 1.75;
  }

  .proof-grid {
    display: grid;
    gap: 0.9rem;
  }

  .proof-card {
    padding: 1rem;
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.035);
    border: 1px solid rgba(255, 255, 255, 0.065);
  }

  .proof-card strong {
    display: block;
    margin-top: 0.45rem;
    font-size: 1rem;
    line-height: 1.55;
    color: var(--fg);
  }

  .showcase,
  .feature-block,
  .inspiration,
  .final-cta {
    margin-top: 1.5rem;
    border-radius: var(--radius-xl);
    padding: clamp(1.4rem, 3vw, 2rem);
  }

  .showcase-header,
  .feature-intro {
    max-width: 48rem;
  }

  .showcase h2,
  .feature-intro h2,
  .inspiration h2,
  .final-cta h2 {
    margin-top: 0.8rem;
    font-size: clamp(2rem, 4vw, 3.4rem);
  }

  .showcase p,
  .feature-intro p,
  .inspiration p {
    margin-top: 0.9rem;
    color: var(--fg-soft);
    line-height: 1.8;
    font-size: 1rem;
  }

  .shot-frame {
    margin-top: 1.4rem;
    border-radius: 24px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(10, 15, 23, 0.96);
  }

  .shot-bar {
    display: flex;
    gap: 0.45rem;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    background: rgba(255, 255, 255, 0.02);
  }

  .shot-bar span {
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.2);
  }

  .shot-image {
    width: 100%;
  }

  .feature-grid {
    margin-top: 1.4rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .feature-card {
    padding: 1.2rem;
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.075);
  }

  .feature-card h3 {
    font-family: var(--font-brand);
    font-size: 1.18rem;
    letter-spacing: -0.03em;
  }

  .feature-card p {
    margin-top: 0.7rem;
    color: var(--fg-soft);
    line-height: 1.75;
  }

  .inspiration {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 1.4rem;
    align-items: start;
  }

  .inspiration a {
    color: var(--accent);
  }

  .final-cta {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
  }

  @media (max-width: 980px) {
    .hero,
    .inspiration,
    .final-cta {
      grid-template-columns: 1fr;
      display: grid;
    }

    .feature-grid {
      grid-template-columns: 1fr;
    }

    .final-cta {
      align-items: start;
    }
  }

  @media (max-width: 640px) {
    .hero-copy,
    .hero-panel,
    .showcase,
    .feature-block,
    .inspiration,
    .final-cta {
      border-radius: 22px;
      padding: 1.25rem;
    }

    .hero h1 {
      font-size: clamp(2.7rem, 16vw, 4.3rem);
    }

    .pillars {
      gap: 0.55rem;
    }

    .pillar,
    .secondary-link,
    .primary-button {
      width: 100%;
      justify-content: center;
    }

    .hero-actions,
    .cta-actions {
      align-items: stretch;
    }
  }
</style>
