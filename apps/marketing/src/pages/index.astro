---
import Layout from "../layouts/Layout.astro";

const githubUrl = "https://github.com/opencoredev/beppo";
const discordUrl = "https://discord.gg/jn4EGJjrvv";

const features = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M12 6v6l4 2"/></svg>`,
    title: "Resilient sessions",
    body: "Threads survive restarts. Reconnects happen invisibly. Your workflow stays unbroken even when the provider stumbles.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
    title: "One focused surface",
    body: "Desktop depth when you're heads-down. Web access when you need to monitor. Same interface, no context switch.",
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3v12"/><path d="M18 9a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/><path d="M6 21a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/><path d="M18 9a9 9 0 0 1-9 9"/></svg>`,
    title: "Built to evolve",
    body: "Its own product voice, its own visual language, and room to grow. An opinionated workspace, not a thin wrapper.",
  },
];
---

<Layout
  title="Beppo — The best way to code with AI"
  description="A desktop-first workspace for running code agents with cleaner sessions and better visibility."
>
  <section class="hero">
    <div class="hero-content">
      <div class="hero-text">
        <span class="badge">
          <span class="badge-dot" aria-hidden="true"></span>
          Open Source AI Coding Web GUI
        </span>

        <h1 class="hero-title">Beppo</h1>

        <p class="hero-tagline">The best way to code with AI.</p>

        <p class="hero-desc">
          A desktop-first workspace for running code agents with cleaner sessions, predictable
          branching, and a UI that stays out of your way.
        </p>

        <div class="hero-actions">
          <a href="/download" class="btn btn-primary">Get Started</a>
          <a href={githubUrl} class="btn btn-ghost" target="_blank" rel="noopener">
            View on GitHub
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>

        <div class="trust-row">
          <span>Open source</span>
          <span class="trust-sep" aria-hidden="true">·</span>
          <span>Codex-powered</span>
          <span class="trust-sep" aria-hidden="true">·</span>
          <span>MIT Licensed</span>
        </div>
      </div>

      <div class="hero-visual">
        <div class="hero-glow" aria-hidden="true"></div>
        <img
          src="/beppo-hero-otter.png"
          alt="Beppo mascot — a cheerful otter surfing a wave"
          width="1536"
          height="1024"
          class="hero-art"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <section class="showcase">
    <div class="window">
      <div class="window-bar">
        <div class="window-dots">
          <span></span><span></span><span></span>
        </div>
        <span class="window-title">Beppo</span>
        <div class="window-dots" style="visibility:hidden;">
          <span></span><span></span><span></span>
        </div>
      </div>
      <div class="window-body">
        <img
          src="/screenshot.jpeg"
          alt="Beppo interface showing a coding session with AI agent"
          width="2764"
          height="1712"
          class="window-img"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <section class="features">
    <div class="features-header">
      <h2 class="section-title">Built for real work</h2>
      <p class="section-desc">
        Not another chat wrapper. Beppo is a dedicated workspace for AI-assisted coding.
      </p>
    </div>
    <div class="features-grid">
      {features.map((f) => (
        <article class="card">
          <div class="card-icon" set:html={f.icon} />
          <h3>{f.title}</h3>
          <p>{f.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="bottom-cta">
    <h2>Ready to try Beppo?</h2>
    <p>Download the latest release from the custom download page, or browse the source on GitHub.</p>
    <div class="bottom-cta-actions">
      <a href="/download" class="btn btn-primary">Download now</a>
      <a href={githubUrl} class="btn btn-ghost" target="_blank" rel="noopener">GitHub</a>
      <a href={discordUrl} class="btn btn-ghost" target="_blank" rel="noopener">Discord</a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    position: relative;
    z-index: 1;
    overflow: hidden;
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: clamp(3rem, 8vh, 6rem) 2rem clamp(2rem, 5vh, 4rem);
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0.9rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    font-size: 0.76rem;
    font-weight: 500;
    color: var(--fg-muted);
    letter-spacing: 0.01em;
    margin-bottom: 1.5rem;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 6px rgba(34, 197, 94, 0.4);
  }

  .hero-title {
    font-family: "Space Grotesk", "DM Sans", sans-serif;
    font-size: clamp(3.2rem, 5.5vw, 5rem);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 0.95;
    margin-bottom: 0.75rem;
  }

  .hero-tagline {
    font-size: clamp(1.1rem, 1.8vw, 1.35rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.35;
    color: var(--fg-muted);
    margin-bottom: 1.25rem;
  }

  .hero-desc {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--fg-dim);
    max-width: 440px;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    flex-wrap: wrap;
    margin-bottom: 1.75rem;
  }

  .trust-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: var(--fg-dim);
  }

  .trust-sep {
    opacity: 0.35;
  }

  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-glow {
    position: absolute;
    width: 120%;
    height: 120%;
    top: -10%;
    left: -10%;
    background: radial-gradient(
      ellipse at 60% 55%,
      rgba(59, 130, 246, 0.06),
      rgba(14, 165, 233, 0.03) 40%,
      transparent 70%
    );
    filter: blur(40px);
    pointer-events: none;
  }

  .hero-art {
    position: relative;
    width: 115%;
    max-width: 640px;
    height: auto;
    object-fit: contain;
    transform: translateX(8%);
    filter: drop-shadow(0 8px 32px rgba(0, 0, 0, 0.3));
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.65rem 1.4rem;
    border-radius: 0.625rem;
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.15s ease;
    cursor: pointer;
    border: none;
    font-family: inherit;
  }

  .btn-primary {
    background: var(--fg);
    color: var(--bg);
  }

  .btn-primary:hover {
    opacity: 0.88;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(250, 250, 250, 0.1);
  }

  .btn-ghost {
    background: transparent;
    color: var(--fg-muted);
    border: 1px solid var(--border);
  }

  .btn-ghost:hover {
    color: var(--fg);
    border-color: rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.04);
  }

  .showcase {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .window {
    position: relative;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: #161616;
    overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.02),
      0 24px 48px -12px rgba(0, 0, 0, 0.5);
  }

  .window-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.55rem 1rem;
    border-bottom: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.012);
  }

  .window-dots {
    display: flex;
    gap: 6px;
  }

  .window-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.07);
  }

  .window-title {
    font-size: 0.72rem;
    color: var(--fg-dim);
    font-weight: 500;
  }

  .window-body {
    position: relative;
  }

  .window-body::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 40%;
    background: linear-gradient(to top, var(--bg), transparent);
    pointer-events: none;
  }

  .window-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .features {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 5rem auto 0;
    padding: 0 2rem;
  }

  .features-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .section-title {
    font-family: "Space Grotesk", "DM Sans", sans-serif;
    font-size: clamp(1.4rem, 2.5vw, 1.85rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }

  .section-desc {
    font-size: 0.95rem;
    color: var(--fg-muted);
    line-height: 1.6;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .card {
    padding: 1.5rem;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.04);
    transition: border-color 0.2s, background 0.2s;
  }

  .card:hover {
    border-color: rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.05);
  }

  .card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border);
    color: var(--fg-muted);
    margin-bottom: 0.85rem;
  }

  .card h3 {
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-bottom: 0.4rem;
  }

  .card p {
    font-size: 0.87rem;
    line-height: 1.6;
    color: var(--fg-muted);
  }

  .bottom-cta {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 540px;
    margin: 5.5rem auto 0;
    padding: 0 2rem;
  }

  .bottom-cta h2 {
    font-family: "Space Grotesk", "DM Sans", sans-serif;
    font-size: clamp(1.3rem, 2.5vw, 1.75rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    margin-bottom: 0.6rem;
  }

  .bottom-cta p {
    font-size: 0.95rem;
    color: var(--fg-muted);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .bottom-cta-actions {
    display: flex;
    justify-content: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  @media (max-width: 960px) {
    .features-grid {
      grid-template-columns: repeat(1, 1fr);
      max-width: 480px;
      margin: 0 auto;
    }
  }

  @media (max-width: 768px) {
    .hero-content {
      grid-template-columns: 1fr;
      text-align: center;
      padding: 2.5rem 1.5rem 2rem;
      gap: 2rem;
    }

    .hero-text {
      align-items: center;
      order: 1;
    }

    .hero-visual {
      order: 2;
    }

    .hero-desc {
      max-width: 100%;
    }

    .hero-art {
      width: 70%;
      max-width: 320px;
      transform: none;
    }

    .hero-glow {
      display: none;
    }

    .hero-actions,
    .trust-row {
      justify-content: center;
    }

    .showcase,
    .features {
      padding: 0 1.25rem;
    }
  }

  @media (max-width: 480px) {
    .hero-title {
      font-size: 2.75rem;
    }

    .hero-actions {
      flex-direction: column;
      width: 100%;
    }

    .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
