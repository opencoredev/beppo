---
import Layout from "../layouts/Layout.astro";
import { DISCORD_URL, RELEASES_URL, REPO_URL } from "../lib/releases";
---

<Layout
  title="Download Beppo"
  description="Download Beppo for macOS, Windows, or Linux."
>
  <h1 class="heading">Download Beppo</h1>
  <p class="subheading">
    <span id="version-label">Loading latest release&hellip;</span>
    <a
      id="changelog-link"
      class="changelog-link"
      href={RELEASES_URL}
      target="_blank"
      rel="noopener noreferrer"
      style="display:none"
    >
      View changelog<span aria-hidden="true"> &#8599;</span>
    </a>
  </p>

  <div class="platforms" id="platforms">
    <section class="platform-section">
      <div class="platform-header">
        <h2 class="platform-name">macOS</h2>
      </div>
      <div class="download-cards">
        <a class="download-card" data-asset="macos-arm64" href={RELEASES_URL}>
          <span class="card-arch">Apple Silicon</span>
          <span class="card-format">arm64 .dmg</span>
        </a>
        <a class="download-card" data-asset="macos-x64" href={RELEASES_URL}>
          <span class="card-arch">Intel</span>
          <span class="card-format">x64 .dmg</span>
        </a>
      </div>
    </section>

    <section class="platform-section">
      <div class="platform-header">
        <h2 class="platform-name">Windows</h2>
      </div>
      <div class="download-cards">
        <a class="download-card" data-asset="windows-x64" href={RELEASES_URL}>
          <span class="card-arch">Windows installer</span>
          <span class="card-format">x64 .zip</span>
        </a>
      </div>
    </section>

    <section class="platform-section">
      <div class="platform-header">
        <h2 class="platform-name">Linux</h2>
      </div>
      <div class="download-cards">
        <a class="download-card" data-asset="linux-x64" href={RELEASES_URL}>
          <span class="card-arch">Linux archive</span>
          <span class="card-format">x64 .tar.gz</span>
        </a>
      </div>
    </section>
  </div>

  <section class="notice-section">
    <h2 class="notice-heading">Install notes</h2>
    <div class="notice-list">
      <div class="notice-card">
        <h3>macOS</h3>
        <p>
          Beppo is not Apple notarized yet. If Gatekeeper blocks first launch, try right-click
          open first. If that still fails, run:
        </p>
        <div class="code-block">
          <pre><code id="xattr-cmd">xattr -dr com.apple.quarantine /Applications/Beppo.app</code></pre>
          <button class="copy-btn" data-target="xattr-cmd" aria-label="Copy to clipboard">
            <svg class="copy-icon copy-icon--default" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            <svg class="copy-icon copy-icon--done" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </button>
        </div>
      </div>

      <div class="notice-card">
        <h3>Windows</h3>
        <p>
          Windows may show the normal SmartScreen warning for an unknown publisher. Click
          <strong> More info </strong> and then <strong> Run anyway </strong> if you trust the
          release source.
        </p>
      </div>

      <div class="notice-card">
        <h3>Linux</h3>
        <p>
          Extract the archive first. If the Beppo binary is not executable yet, run:
        </p>
        <div class="code-block">
          <pre><code id="linux-chmod-cmd">chmod +x path/to/Beppo</code></pre>
          <button class="copy-btn" data-target="linux-chmod-cmd" aria-label="Copy to clipboard">
            <svg class="copy-icon copy-icon--default" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            <svg class="copy-icon copy-icon--done" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </button>
        </div>
      </div>
    </div>
  </section>

  <p class="releases-link">
    Need the source or older builds?
    <a href={REPO_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
    <span aria-hidden="true"> · </span>
    <a href={RELEASES_URL} target="_blank" rel="noopener noreferrer">Releases</a>
    <span aria-hidden="true"> · </span>
    <a href={DISCORD_URL} target="_blank" rel="noopener noreferrer">Discord</a>
  </p>
</Layout>

<script>
  import { fetchLatestRelease, findDownloadAsset, RELEASES_URL } from "../lib/releases";

  async function init() {
    const versionLabel = document.getElementById("version-label");
    const changelogLink = document.getElementById("changelog-link") as HTMLAnchorElement | null;
    const cards = document.querySelectorAll<HTMLAnchorElement>(".download-card");

    try {
      const release = await fetchLatestRelease();

      if (versionLabel && release.tag_name) {
        versionLabel.textContent = `Latest public release: ${release.tag_name}`;
      }

      if (changelogLink && release.html_url) {
        changelogLink.href = release.html_url;
        changelogLink.style.display = "";
      }

      cards.forEach((card) => {
        const target = card.dataset.asset;
        if (!target) return;
        const match = findDownloadAsset(
          release.assets ?? [],
          target as Parameters<typeof findDownloadAsset>[1],
        );
        card.href = match?.browser_download_url ?? RELEASES_URL;
      });
    } catch {
      if (versionLabel) {
        versionLabel.textContent = "Could not load release info.";
      }
      cards.forEach((card) => {
        card.href = RELEASES_URL;
      });
    }
  }

  init();

  document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const target = document.getElementById(btn.dataset.target ?? "");
      if (!target) return;

      try {
        await navigator.clipboard.writeText(target.textContent ?? "");
        btn.classList.add("copied");
        setTimeout(() => btn.classList.remove("copied"), 2000);
      } catch {
        // Ignore clipboard failures.
      }
    });
  });
</script>

<style>
  .main {
    padding: 8vh 1.5rem 4rem;
  }

  .heading {
    font-weight: 500;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    letter-spacing: -0.035em;
    line-height: 1.15;
    text-align: center;
    margin-bottom: 0.5rem;
    opacity: 0;
    animation: fade-in 1s ease-out forwards;
  }

  .subheading {
    font-size: 0.9rem;
    color: var(--fg-dim);
    margin-bottom: 3rem;
    opacity: 0;
    animation: fade-in 1s ease-out 0.1s forwards;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .changelog-link {
    color: var(--fg-muted);
    font-size: 0.8rem;
    text-decoration: underline;
    text-decoration-color: rgba(161, 161, 170, 0.4);
    text-underline-offset: 3px;
  }

  .platforms {
    width: 100%;
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    opacity: 0;
    animation: fade-in 1s ease-out 0.2s forwards;
  }

  .platform-section {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .platform-header {
    display: flex;
    align-items: center;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .platform-name {
    font-weight: 500;
    font-size: 1.1rem;
    letter-spacing: -0.01em;
  }

  .download-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }

  .download-card {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--border);
    border-radius: 0.875rem;
    background: rgba(255, 255, 255, 0.03);
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
  }

  .download-card:hover {
    border-color: rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.05);
    transform: translateY(-1px);
  }

  .card-arch {
    font-size: 0.95rem;
    font-weight: 500;
  }

  .card-format {
    font-size: 0.8rem;
    color: var(--fg-dim);
  }

  .notice-section {
    width: 100%;
    max-width: 720px;
    margin-top: 3rem;
    opacity: 0;
    animation: fade-in 1s ease-out 0.3s forwards;
  }

  .notice-heading {
    font-size: 1.2rem;
    font-weight: 500;
    margin-bottom: 1rem;
  }

  .notice-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .notice-card {
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 0.875rem;
    background: rgba(255, 255, 255, 0.03);
  }

  .notice-card h3 {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.45rem;
  }

  .notice-card p {
    color: var(--fg-muted);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  .code-block {
    margin-top: 0.85rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--border);
    border-radius: 0.875rem;
    background: rgba(255, 255, 255, 0.02);
  }

  .code-block pre {
    margin: 0;
    overflow-x: auto;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.83rem;
    color: var(--fg);
    white-space: pre-wrap;
    word-break: break-word;
  }

  .copy-btn {
    position: relative;
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    border: 1px solid var(--border);
    border-radius: 0.625rem;
    background: transparent;
    color: var(--fg-muted);
    cursor: pointer;
  }

  .copy-btn:hover {
    color: var(--fg);
    border-color: rgba(255, 255, 255, 0.14);
  }

  .copy-icon {
    position: absolute;
    inset: 0;
    margin: auto;
  }

  .copy-icon--done {
    opacity: 0;
  }

  .copy-btn.copied .copy-icon--default {
    opacity: 0;
  }

  .copy-btn.copied .copy-icon--done {
    opacity: 1;
  }

  .releases-link {
    margin-top: 2rem;
    color: var(--fg-dim);
    font-size: 0.85rem;
    opacity: 0;
    animation: fade-in 1s ease-out 0.4s forwards;
  }

  .releases-link a {
    color: var(--fg-muted);
  }

  .releases-link a:hover {
    color: var(--fg);
  }

  @media (max-width: 640px) {
    .download-cards {
      grid-template-columns: 1fr;
    }

    .code-block {
      align-items: flex-start;
    }
  }
</style>
