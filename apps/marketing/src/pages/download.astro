---
import Layout from "../layouts/Layout.astro";
import { DISCORD_URL, RELEASES_URL, REPO_URL } from "../lib/releases";
---

<Layout
  title="Download Beppo"
  description="Download Beppo for macOS, Windows, or Linux and review the latest release notes on GitHub."
>
  <section class="download-hero">
    <div>
      <span class="eyebrow">Download Beppo</span>
      <h1>Grab the latest desktop build.</h1>
      <p class="lede">
        Direct downloads are pulled from the latest GitHub release so the page stays current with
        what Beppo actually ships.
      </p>
    </div>

    <div class="release-card">
      <span class="release-label">Release status</span>
      <p id="version-label" class="release-version">Loading latest release...</p>
      <div class="release-actions">
        <a
          id="changelog-link"
          class="secondary-link"
          href={RELEASES_URL}
          target="_blank"
          rel="noopener noreferrer"
          style="display:none"
        >
          View changelog
        </a>
        <a class="secondary-link" href={REPO_URL} target="_blank" rel="noopener noreferrer">
          Source code
        </a>
      </div>
    </div>
  </section>

  <section class="downloads-grid" id="platforms">
    <article class="platform-panel">
      <div class="platform-heading">
        <svg class="platform-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 814 1000" aria-hidden="true"><path fill="currentColor" d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57-155.5-127C46.7 790.7 0 663 0 541.8c0-194.4 126.4-297.5 250.8-297.5 66.1 0 121.2 43.4 162.7 43.4 39.5 0 101.1-46 176.3-46 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"/></svg>
        <div>
          <h2>macOS</h2>
          <p>Universal DMG options for Apple Silicon and Intel Macs.</p>
        </div>
      </div>
      <div class="download-cards">
        <a class="download-card" data-asset="macos-arm64" href={RELEASES_URL}>
          <span class="card-arch">Apple Silicon (arm64)</span>
          <span class="card-format">.dmg</span>
        </a>
        <a class="download-card" data-asset="macos-x64" href={RELEASES_URL}>
          <span class="card-arch">Intel (x64)</span>
          <span class="card-format">.dmg</span>
        </a>
      </div>
    </article>

    <article class="platform-panel">
      <div class="platform-heading">
        <svg class="platform-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 88 88" aria-hidden="true"><path fill="currentColor" d="m0 12.402 35.687-4.86.016 34.423-35.67.203zm35.67 33.529.028 34.453L.028 75.48.026 45.7zm4.326-39.025L87.314 0v41.527l-47.318.376zm47.329 39.349-.011 41.34-47.318-6.678-.066-34.739z"/></svg>
        <div>
          <h2>Windows</h2>
          <p>Installer build for current Windows machines.</p>
        </div>
      </div>
      <div class="download-cards">
        <a class="download-card" data-asset="windows-x64" href={RELEASES_URL}>
          <span class="card-arch">Windows 10, 11</span>
          <span class="card-format">.exe</span>
        </a>
      </div>
    </article>

    <article class="platform-panel">
      <div class="platform-heading">
        <svg class="platform-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 295" aria-hidden="true"><defs><linearGradient id="download-linux-a" x1="48.548%" x2="51.047%" y1="115.276%" y2="41.364%"><stop offset="0%" stop-color="#FFEED7"/><stop offset="100%" stop-color="#BDBFC2"/></linearGradient><linearGradient id="download-linux-b" x1="49.984%" x2="49.984%" y1="89.845%" y2="40.632%"><stop offset="0%" stop-color="#FFEED7"/><stop offset="100%" stop-color="#BDBFC2"/></linearGradient><linearGradient id="download-linux-c" x1="49.841%" x2="50.241%" y1="13.229%" y2="94.673%"><stop offset="0%" stop-color="#FFF" stop-opacity=".8"/><stop offset="100%" stop-color="#FFF" stop-opacity="0"/></linearGradient><linearGradient id="download-linux-d" x1="53.467%" x2="38.949%" y1="48.921%" y2="98.1%"><stop offset="0%" stop-color="#FFA63F"/><stop offset="100%" stop-color="#FF0"/></linearGradient><linearGradient id="download-linux-e" x1="30.581%" x2="65.887%" y1="34.024%" y2="89.175%"><stop offset="0%" stop-color="#FFA63F"/><stop offset="100%" stop-color="#FF0"/></linearGradient><linearGradient id="download-linux-f" x1="49.733%" x2="50.558%" y1="17.609%" y2="99.385%"><stop offset="0%" stop-color="#FFA63F"/><stop offset="100%" stop-color="#FF0"/></linearGradient></defs><g fill="none"><path fill="#000" d="M63.213 215.474c-11.387-16.346-13.591-69.606 12.947-102.39C89.292 97.383 92.69 86.455 93.7 71.67c.734-16.805-11.846-66.851 35.537-70.616 48.027-3.857 45.364 43.526 45.088 68.596-.183 21.12 15.52 33.15 26.355 49.68 19.927 30.303 18.274 82.461-3.765 110.745-27.916 35.354-51.791 20.018-67.678 21.304-29.752 1.745-30.762 17.54-66.024-35.905"/><path fill="url(#download-linux-b)" d="M81.027 145.684c6.52-14.785 20.386-40.772 20.662-60.883 0-15.978 47.843-19.835 51.7-3.856 3.856 15.978 13.59 39.853 19.834 51.424 6.245 11.478 24.335 48.118 5.051 80.074-17.356 28.284-69.973 50.69-98.073-3.856-9.55-18.917-7.806-42.333.826-62.903"/><path fill="url(#download-linux-c)" d="M166.428 151.285c0 16.162-15.519 37.1-42.15 36.916-27.456.183-39.118-20.754-39.118-36.916 0-16.161 18.182-29.293 40.588-29.293 22.498.092 40.68 13.132 40.68 29.293"/><path fill="#000" stroke="#000" stroke-width=".977" d="M176.805 117.86c13.59 11.02 38.292 49.587 2.204 74.748-11.846 7.806 10.468 32.508 23.049 19.927 43.618-43.894-1.102-94.308-16.53-111.664-13.774-15.151-25.987 3.49-8.723 16.989z"/><path fill="#000" stroke="#000" stroke-width="1.25" d="M79.925 122.727c-8.907 14.509-30.211 48.669-1.652 66.484 38.384 23.6 27.548 47.108-7.53 25.895-49.404-29.568-5.97-89.257 13.774-112.03 22.59-25.529 4.316 4.683-4.592 19.65z"/><path fill="url(#download-linux-d)" stroke="#E68C3F" stroke-width="6.25" d="M51.835 258.542c-20.57-10.928-50.414 2.112-39.578-27.457 2.204-6.704-3.214-16.805.275-23.325 4.133-7.989 13.04-6.244 18.366-11.57 5.234-5.51 8.54-15.06 18.366-13.59 9.734 1.468 16.254 13.406 23.049 28.099 5.05 10.468 22.865 25.253 21.672 37.007-1.47 17.998-21.948 21.396-42.15 10.836z" transform="translate(10)"/><path fill="url(#download-linux-e)" stroke="#E68C3F" stroke-width="6.251" d="M194.445 253.49c15.06-18.273 48.578-14.508 25.988-39.577-4.775-5.418-3.306-16.989-9.183-21.947-6.887-6.061-14.509-1.102-21.488-4.224-6.979-3.398-14.325-9.918-22.865-5.327-8.54 4.684-9.459 16.805-10.285 32.783-.735 11.479-11.203 30.671-5.602 41.231 8.081 16.346 29.11 14.142 43.435-2.938z" transform="translate(10)"/><path fill="url(#download-linux-f)" stroke="#E68C3F" stroke-width="3.75" d="M97.107 66.344c3.673-3.398 12.58-13.774 29.477-2.939 3.122 2.02 5.693 2.204 11.662 4.775 12.03 4.96 6.336 16.897-6.52 20.937-5.51 1.745-10.468 8.449-20.386 7.806-8.54-.46-10.744-6.06-15.978-9.091-9.275-5.234-10.652-12.305-5.602-16.07 5.051-3.765 6.98-5.143 7.347-5.418z" transform="translate(10)"/><path fill="#000" d="M133.186 57.712c-.092 5.234 2.48 9.458 5.877 9.458 3.306 0 6.153-4.224 6.245-9.366.091-5.234-2.48-9.459-5.878-9.459-3.397 0-6.152 4.225-6.244 9.367m-21.212.092c.459 4.316-1.194 7.989-3.582 8.356-2.387.276-4.683-2.938-5.142-7.254-.46-4.316 1.194-7.99 3.581-8.357 2.388-.275 4.684 2.939 5.143 7.255"/></g></svg>
        <div>
          <h2>Linux</h2>
          <p>Portable AppImage build for current desktop distributions.</p>
        </div>
      </div>
      <div class="download-cards">
        <a class="download-card" data-asset="linux-x64" href={RELEASES_URL}>
          <span class="card-arch">x86_64</span>
          <span class="card-format">AppImage</span>
        </a>
      </div>
    </article>
  </section>

  <section class="notes-grid">
    <article class="note-panel">
      <span class="eyebrow">macOS note</span>
      <h2>If Gatekeeper blocks Beppo on first launch</h2>
      <p>
        Current macOS builds may still require the usual unsigned-app first-run flow. If Finder
        blocks the app, try the standard right-click open path first. If that still fails, run:
      </p>
      <div class="code-block">
        <pre><code id="xattr-cmd">xattr -dr com.apple.quarantine /Applications/Beppo.app</code></pre>
        <button class="copy-btn" data-target="xattr-cmd" aria-label="Copy to clipboard">
          <svg class="copy-icon copy-icon--default" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          <svg class="copy-icon copy-icon--done" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </button>
      </div>
    </article>

    <article class="note-panel">
      <span class="eyebrow">Need more context?</span>
      <h2>Release notes, source, and support stay public.</h2>
      <p>
        Older versions live on GitHub, release notes are linked per build, and the fastest place to
        ask for help is the Beppo community Discord.
      </p>
      <div class="support-links">
        <a class="secondary-link" href={RELEASES_URL} target="_blank" rel="noopener noreferrer">
          Older releases
        </a>
        <a class="secondary-link" href={DISCORD_URL} target="_blank" rel="noopener noreferrer">
          Community Discord
        </a>
      </div>
    </article>
  </section>
</Layout>

<script>
  import { fetchLatestRelease, findDownloadAsset, RELEASES_URL } from "../lib/releases";

  async function init() {
    const versionLabel = document.getElementById("version-label");
    const changelogLink = document.getElementById("changelog-link") as HTMLAnchorElement | null;
    const cards = document.querySelectorAll<HTMLAnchorElement>(".download-card");

    try {
      const release = await fetchLatestRelease();

      if (versionLabel && release.tag_name) {
        versionLabel.textContent = `Latest public release: ${release.tag_name}`;
      }

      if (changelogLink && release.html_url) {
        changelogLink.href = release.html_url;
        changelogLink.style.display = "";
      }

      cards.forEach((card) => {
        const suffix = card.dataset.asset;
        if (!suffix) return;

        const match = findDownloadAsset(release.assets ?? [], suffix as Parameters<
          typeof findDownloadAsset
        >[1]);
        card.href = match?.browser_download_url ?? RELEASES_URL;
      });
    } catch {
      if (versionLabel) {
        versionLabel.textContent = "Could not load release metadata.";
      }

      cards.forEach((card) => {
        card.href = RELEASES_URL;
      });
    }
  }

  init();

  document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((button) => {
    button.addEventListener("click", async () => {
      const target = document.getElementById(button.dataset.target ?? "");
      if (!target) return;

      try {
        await navigator.clipboard.writeText(target.textContent ?? "");
        button.classList.add("copied");
        setTimeout(() => button.classList.remove("copied"), 2000);
      } catch {
        // Ignore clipboard failures in browsers that block programmatic copy.
      }
    });
  });
</script>

<style>
  .download-hero,
  .platform-panel,
  .note-panel {
    animation: rise-in 0.6s ease forwards;
  }

  .download-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
    gap: 1.2rem;
    align-items: stretch;
  }

  .download-hero,
  .platform-panel,
  .note-panel {
    border: 1px solid var(--line);
    background: linear-gradient(180deg, rgba(11, 18, 28, 0.9), rgba(8, 13, 21, 0.82));
    box-shadow: var(--shadow);
    border-radius: var(--radius-xl);
    padding: clamp(1.3rem, 3vw, 1.9rem);
  }

  .eyebrow,
  .release-label {
    display: inline-flex;
    color: var(--accent);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1,
  h2 {
    font-family: var(--font-brand);
    letter-spacing: -0.05em;
    line-height: 0.98;
  }

  h1 {
    margin-top: 0.8rem;
    font-size: clamp(2.8rem, 6vw, 4.8rem);
  }

  .lede,
  .release-card,
  .platform-heading p,
  .note-panel p {
    color: var(--fg-soft);
    line-height: 1.8;
  }

  .lede {
    margin-top: 1rem;
    max-width: 42rem;
    font-size: 1.02rem;
  }

  .release-card {
    padding: 1rem;
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1rem;
  }

  .release-version {
    font-size: 1.05rem;
    color: var(--fg);
  }

  .release-actions,
  .support-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .downloads-grid,
  .notes-grid {
    margin-top: 1.4rem;
    display: grid;
    gap: 1rem;
  }

  .downloads-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .notes-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .platform-heading {
    display: flex;
    gap: 0.9rem;
    align-items: flex-start;
  }

  .platform-icon {
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .platform-heading h2,
  .note-panel h2 {
    font-size: 1.45rem;
  }

  .platform-heading p,
  .note-panel p {
    margin-top: 0.55rem;
  }

  .download-cards {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 1.1rem;
  }

  .download-cards.single {
    grid-template-columns: 1fr;
  }

  .download-card,
  .secondary-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    border-radius: 18px;
    transition: transform 0.16s ease, border-color 0.16s ease, background 0.16s ease;
  }

  .download-card {
    padding: 1rem;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-start;
    background: rgba(255, 255, 255, 0.035);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .download-card:hover,
  .secondary-link:hover {
    transform: translateY(-1px);
    border-color: var(--line-strong);
    background: rgba(255, 255, 255, 0.05);
  }

  .card-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--fg);
  }

  .card-meta {
    margin-top: 0.35rem;
    color: var(--fg-dim);
    font-size: 0.88rem;
  }

  .secondary-link {
    padding: 0.78rem 1rem;
    border: 1px solid var(--line);
    color: var(--fg-soft);
    background: rgba(255, 255, 255, 0.02);
  }

  .code-block {
    position: relative;
    margin-top: 1rem;
    padding: 0.95rem 3rem 0.95rem 1rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    overflow-x: auto;
  }

  .code-block code {
    font-family: "SF Mono", "Fira Code", "Roboto Mono", "Menlo", monospace;
    color: var(--fg-soft);
    font-size: 0.85rem;
  }

  .copy-btn {
    position: absolute;
    top: 50%;
    right: 0.75rem;
    transform: translateY(-50%);
    width: 2rem;
    height: 2rem;
    border: none;
    border-radius: 10px;
    color: var(--fg-dim);
    background: transparent;
    cursor: pointer;
    transition: background 0.16s ease, color 0.16s ease;
  }

  .copy-btn:hover {
    background: rgba(255, 255, 255, 0.07);
    color: var(--fg);
  }

  .copy-icon--done {
    display: none;
  }

  .copy-btn.copied .copy-icon--default {
    display: none;
  }

  .copy-btn.copied .copy-icon--done {
    display: block;
    color: var(--success);
  }

  @media (max-width: 980px) {
    .download-hero,
    .downloads-grid,
    .notes-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .download-hero,
    .platform-panel,
    .note-panel {
      border-radius: 22px;
      padding: 1.2rem;
    }

    .download-cards,
    .release-actions,
    .support-links {
      grid-template-columns: 1fr;
      flex-direction: column;
    }

    .download-card,
    .secondary-link {
      width: 100%;
    }

    .code-block {
      padding-right: 2.6rem;
    }

    .code-block code {
      font-size: 0.78rem;
    }
  }
</style>
